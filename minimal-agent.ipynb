import os
from typing import Literal
from pydantic import BaseModel, Field
from pydantic_ai import Agent, RunContext
from pydantic_ai.models.amazon_bedrock import BedrockModel
from mcp import ClientSession, StdioServerParameters # Standard MCP imports

# 1. DEFINE STRUCTURED OUTPUT SCHEMA [12, 13]
class SeverityResult(BaseModel):
    """Schema for incident classification to ensure system reliability."""
    level: Literal['P1', 'P2', 'P3', 'P4'] = Field(description="Severity level")
    summary: str = Field(description="A concise summary of the issue")
    rational: str = Field(description="Reasoning for the assigned severity")

# 2. INITIALIZE THE PRODUCTION AGENT [12, 14]
# Using a cost-effective reasoning engine (Nova Light) as suggested in sources [13, 14]
model = BedrockModel('amazon.nova-light-v1-0')
agent = Agent(
    model,
    result_type=SeverityResult,
    # System Prompt with explicit guardrails for production [15, 16]
    system_prompt=(
        "You are an incident triage agent. Classify complaints from P1 to P4. "
        "1. Call 'store_incident' to save data to DynamoDB. "
        "2. Call 'notify_incident' for P1/P2 issues via SNS. "
        "3. Use 'lookup_kb' to search for known workarounds. "
        "Call each tool exactly once. Do not mention tool calls in your summary."
    ),
    retries=2 # Built-in retry logic for semantic/transient failures [9, 12]
)

# 3. DEFINE IDEMPOTENT TOOLS [17-20]
@agent.tool
async def store_incident(ctx: RunContext, data: SeverityResult) -> str:
    """Stores incident in DynamoDB. Idempotent to prevent duplicates [9]."""
    # Logic to interact with boto3/DynamoDB [19]
    # In production, use a uniqueness key (e.g., hash of customer text) [9]
    return "Incident successfully stored in 'incident_table'."

@agent.tool
async def notify_incident(ctx: RunContext, severity: str) -> str:
    """Triggers SNS notification for high-priority incidents [20, 21]."""
    if severity in ['P1', 'P2']:
        # Logic for AWS SNS publish [20]
        return f"Stakeholders notified of {severity} incident."
    return "Notification skipped (low priority)."

# 4. MCP INTEGRATION FOR KNOWLEDGE DISCOVERY [22-24]
@agent.tool
async def lookup_kb(ctx: RunContext, query: str) -> str:
    """Standardized tool discovery using Model Context Protocol (MCP) [25, 26]."""
    # This acts as a 'USB-C' connector to external knowledge servers [25]
    # In production, you would handshake with an MCP server (e.g., OpenAI Docs) [27-29]
    return "MCP KB: 'Standard workaround for checkout failures is cache clearing'."

# 5. MULTI-AGENT ORCHESTRATION (SUB-AGENT CALL) [30-37]
@agent.tool
async def deep_security_review(ctx: RunContext, text: str) -> str:
    """Invokes a specialized sub-agent for security analysis [32, 36]."""
    # The parent (Triage) delegates to a specialized worker (Security Specialist) [33, 38]
    security_agent = Agent('amazon.nova-pro-v1-0', system_prompt="Check for PII leaks.")
    result = await security_agent.run(text)
    return result.data
